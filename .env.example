# Copie para .env na raiz do projeto (não commite o .env)

# URL pública — obrigatório para links no celular/WhatsApp
# Local (mesma Wi‑Fi): http://192.168.x.x:8080
# Produção (Vercel):   https://seu-app.vercel.app
VITE_APP_URL=

# URL do projeto (sem /rest/v1/ no final)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AdSense — slot da unidade Display no rodapé (crie em AdSense → Anúncios → Por unidade)
# VITE_ADSENSE_FOOTER_SLOT=1234567890

# Mercado Pago (Checkout Transparente PIX)
# Use APENAS a Public Key no frontend (VITE_*)
# VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# Monetag — ID da zona no rodapé (opcional; prefira embed HTML via Super ADM)
# VITE_MONETAG_FOOTER_ZONE=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

FOOTBALL_API_BASE=https://v3.football.api-sports.io
FOOTBALL_API_KEY=

# Mercado Pago — token privado (backend apenas)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# Assinatura do webhook (opcional, recomendado)
# MERCADOPAGO_WEBHOOK_SECRET=

PLATFORM_FEE_PERCENT=10
NODE_ENV=production
